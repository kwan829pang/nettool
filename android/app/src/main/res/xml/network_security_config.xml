<?xml version="1.0" encoding="utf-8"?>
<!-- Cleartext HTTP is required for LAN internal speed tests to private IPv4 hosts. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
